{
  "name": "vorinthex-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "load-local-env": "bun run ../.github/scripts/write-local-env.ts dev backend backend/.env.local",
    "dev": "bun run load-local-env && bun --env-file=.env.local run --hot src/api/index.ts",
    "dev:infra": "docker compose up -d arangodb redis localstack mailpit",
    "dev:services": "docker compose --profile services up",
    "start": "bun run scripts/dev-start.ts",
    "start:server": "bun run load-local-env && bun --env-file=.env.local run src/api/index.ts",
    "start:app": "bun run load-local-env && bun --env-file=.env.local run src/api/index.ts",
    "start:render": "bun run load-local-env && bun --env-file=.env.local run src/render-worker/index.ts",
    "reset": "bun run scripts/reset.ts",
    "create:super-admin": "bun run scripts/create-super-admin.ts",
    "nodes": "bun run scripts/nodes.ts",
    "check": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "db:migrate": "bun run load-local-env && bun --env-file=.env.local src/db/arango-migrate.ts",
    "db:migrate:dev": "bun run load-local-env && bun --env-file=.env.local src/db/arango-migrate.ts",
    "db:migrate:ci": "bun run src/db/arango-migrate.ts",
    "seed.ts": "bun run load-local-env && bun --env-file=.env.local src/lib/db/seed.ts",
    "db:seed": "bun run load-local-env && bun --env-file=.env.local src/db/seed-all.ts",
    "seed:secrets": "bun run scripts/seed-secrets.ts",
    "polar:sync": "bun run scripts/sync-polar-products.ts",
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1000.0",
    "@smithy/node-http-handler": "^4.9.8",
    "@aws-sdk/client-s3": "^3.750.0",
    "@google/generative-ai": "^0.24.1",
    "@otplib/plugin-base32-scure": "^13.4.1",
    "@otplib/plugin-crypto-noble": "^13.4.1",
    "@otplib/totp": "^13.4.1",
    "@paralleldrive/cuid2": "^2.2.2",
    "@sparticuz/chromium": "^149.0.0",
    "arangojs": "^9.3.0",
    "cuid": "^3.0.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.18",
    "ioredis": "^5.4.0",
    "nodemailer": "^9.0.3",
    "openai": "^6.44.0",
    "otplib": "^13.4.1",
    "puppeteer-core": "^25.2.1",
    "qrcode": "^1.5.4",
    "svix": "^1.96.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.0"
  }
}
