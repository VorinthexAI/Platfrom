# Caddy reverse proxy for the single-box early-infra app host.
# Rendered by deploy.sh with __COLOR__ replaced by the active color (blue|green).
#
# Cloudflare is the client (proxied) and forwards the real Host header, which we
# route on: api.vorinthex.com -> Bun backend (:3001); everything else -> Next.js
# web (:3000, fans other subdomains out via proxy.ts).
#
# Serves :80 (Cloudflare "Flexible") AND :443 with a self-signed internal cert for
# vorinthex.com + *.vorinthex.com (Cloudflare "Full", non-strict). local_certs
# forces Caddy's internal CA so it never reaches out to Let's Encrypt.

{
	admin off
	local_certs
}

(routes) {
	@api header Host api.vorinthex.com
	handle @api {
		reverse_proxy api-__COLOR__:3001 {
			flush_interval -1
		}
	}
	handle {
		reverse_proxy web-__COLOR__:3000 {
			flush_interval -1
		}
	}
}

:80 {
	import routes
}

https://vorinthex.com, https://*.vorinthex.com {
	tls internal
	import routes
}
