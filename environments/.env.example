# =============================================================================
# Vorinthex platform environment
# =============================================================================
#
# This file is intentionally shared by the vorinthex, orbit, and
# backend workspaces. Every key is prefixed with the project that owns it
# (VORINTHEX_, ORBIT_, BACKEND_) so it's unambiguous which project a
# value belongs to and where it ends up (Vercel project env vs backend SSM).
# NODE_ENV is the only shared, unprefixed key.
#
# environments/scripts/scoped-env.ts strips the prefix for local dev/start
# scripts; .github/workflows/deploy.yml does the same when syncing production
# values to each Vercel project and to SSM for the backend.
#
# Keep the same key order in .env.example, .env.dev, and .env.prod.


# =============================================================================
# Shared values
# =============================================================================

# Runtime environment name; use development locally and production in deployed services.
NODE_ENV=development


# =============================================================================
# Vorinthex web values
# =============================================================================

# Public base URL that browser-side vorinthex code uses when calling the backend API.
VORINTHEX_NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Canonical public vorinthex URL used for metadata, robots, sitemap, and absolute links.
VORINTHEX_NEXT_PUBLIC_SITE_URL=https://vorinthex.com

# Publicly exposed backend API key used by vorinthex browser calls when an endpoint requires the shared API key.
VORINTHEX_NEXT_PUBLIC_BACKEND_API_KEY=placeholder-backend-api-key

# Public WebSocket base URL used by vorinthex browser-side realtime features.
VORINTHEX_NEXT_PUBLIC_WS_BASE_URL=ws://localhost:3001

# Server-side backend API base URL used by vorinthex's Next.js route handlers and server components.
VORINTHEX_API_BASE_URL=http://localhost:3001

# Server-side backend API key used by vorinthex's Next.js route handlers; prefer this over the public key for server-only calls.
VORINTHEX_BACKEND_API_KEY=placeholder-backend-api-key

# Secret used to sign or encrypt vorinthex session cookies.
VORINTHEX_SESSION_COOKIE_SECRET=change-me

# Fallback session secret used by vorinthex auth/session helpers when VORINTHEX_SESSION_COOKIE_SECRET is not set.
VORINTHEX_SESSION_SECRET=change-me


# =============================================================================
# Orbit web values
# =============================================================================

# Public base URL that browser-side orbit code uses when calling the backend API.
ORBIT_NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Canonical public orbit URL used for metadata, robots, sitemap, and absolute links.
ORBIT_NEXT_PUBLIC_SITE_URL=https://orbit.ai

# Publicly exposed backend API key used by orbit browser calls when an endpoint requires the shared API key.
ORBIT_NEXT_PUBLIC_BACKEND_API_KEY=placeholder-backend-api-key

# Server-side backend API base URL used by orbit's Next.js route handlers and server components.
ORBIT_API_BASE_URL=http://localhost:3001

# Server-side backend API key used by orbit's Next.js route handlers; prefer this over the public key for server-only calls.
ORBIT_BACKEND_API_KEY=placeholder-backend-api-key

# Secret used to sign or encrypt orbit session cookies.
ORBIT_SESSION_COOKIE_SECRET=change-me

# Fallback session secret used by orbit auth/session helpers when ORBIT_SESSION_COOKIE_SECRET is not set.
ORBIT_SESSION_SECRET=change-me


# =============================================================================
# Backend values
# =============================================================================

# Backend HTTP port.
BACKEND_PORT=3001

# Frontend URL used by backend-generated email links and redirects.
BACKEND_FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed browser origins for backend CORS.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Backend API key accepted by the API key middleware.
BACKEND_API_KEY=change-me

# Set true to enable Redis-backed per-IP backend rate limiting.
BACKEND_RATE_LIMIT_ENABLED=false

# Legacy per-minute backend rate limit value.
BACKEND_RATE_LIMIT_REQ_PER_MIN=60

# Preferred maximum number of backend requests allowed per rate-limit window.
BACKEND_RATE_LIMIT_MAX_REQUESTS=

# Backend rate-limit window size in seconds.
BACKEND_RATE_LIMIT_WINDOW_SECONDS=

# Redis connection URL used by queues, rate limiting, and sweeps.
BACKEND_REDIS_URL=redis://127.0.0.1:6380

# ArangoDB HTTP endpoint used by backend database clients and migrations.
BACKEND_ARANGO_URL=http://127.0.0.1:8529

# ArangoDB database name.
BACKEND_ARANGO_DATABASE=vorinthex

# ArangoDB username.
BACKEND_ARANGO_USERNAME=root

# ArangoDB password for the configured user.
BACKEND_ARANGO_ROOT_PASSWORD=vorinthex

# AWS region for S3, SSM, ECR, ECS, and other AWS calls.
BACKEND_AWS_REGION=eu-north-1

# Optional AWS-compatible endpoint override, usually LocalStack in development.
BACKEND_AWS_ENDPOINT_URL=http://127.0.0.1:4566

# AWS access key for local development or non-OIDC runtime calls.
BACKEND_AWS_ACCESS_KEY_ID=test

# AWS secret access key for local development or non-OIDC runtime calls.
BACKEND_AWS_SECRET_ACCESS_KEY=test

# S3 bucket used by backend storage and render outputs.
BACKEND_S3_BUCKET=vorinthex-dev

# Secret used to sign backend access tokens.
BACKEND_ACCESS_TOKEN_SECRET=change-me

# Secret used to encrypt stored TOTP secrets.
BACKEND_TOTP_SECRET_ENCRYPTION_KEY=change-me

# Polar environment name: sandbox or production.
BACKEND_POLAR_SERVER=sandbox

# Polar API access token used for product and payment operations.
BACKEND_POLAR_ACCESS_TOKEN=

# Polar webhook signing secret.
BACKEND_POLAR_WEBHOOK_SECRET=

# Development-only flag that allows unsigned Polar webhooks when explicitly true.
BACKEND_POLAR_SKIP_WEBHOOK_VERIFICATION=false

# Resend webhook signing secret.
BACKEND_RESEND_WEBHOOK_SECRET=

# SMTP server hostname used for outbound email.
BACKEND_SMTP_HOST=127.0.0.1

# SMTP server port used for outbound email.
BACKEND_SMTP_PORT=1025

# SMTP username used for outbound email.
BACKEND_SMTP_USER=mailpit

# SMTP password used for outbound email.
BACKEND_SMTP_PASS=mailpit

# Default from-address for transactional email.
BACKEND_NO_REPLY_EMAIL=no-reply@example.local

# Anthropic API key for model providers.
BACKEND_ANTHROPIC_API_KEY=

# OpenAI API key for model providers.
BACKEND_OPENAI_API_KEY=

# Grok API key for model providers.
BACKEND_GROK_API_KEY=

# Perplexity API key for model providers.
BACKEND_PERPLEXITY_API_KEY=

# Google Generative AI API key for model providers.
BACKEND_GOOGLE_API_KEY=

# Administrative email used for operational notifications and bootstrap flows.
BACKEND_ADMIN_EMAIL=

# Local path to the production SSH private key used by backend management scripts.
BACKEND_PROD_SSH_KEY_PATH=

# Production app host SSH hostname used by backend management scripts.
BACKEND_PROD_SSH_HOST=

# Production SSH username used by backend management scripts.
BACKEND_PROD_SSH_USER=ec2-user

# ArangoDB host as seen from the production SSH tunnel endpoint.
BACKEND_PROD_ARANGO_REMOTE_HOST=127.0.0.1

# Production graph database host SSH hostname used to open ArangoDB tunnels.
BACKEND_PROD_ARANGO_SSH_HOST=

# Local port used when backend scripts open an ArangoDB SSH tunnel.
BACKEND_PROD_ARANGO_LOCAL_PORT=
