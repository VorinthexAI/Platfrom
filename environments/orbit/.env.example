# =============================================================================
# Orbit web environment
# =============================================================================
#
# Only this app reads this file — no prefixes needed since it's not shared
# with vorinthex or backend. Keep the same key order in .env.example,
# .env.dev, and .env.prod.

# Runtime environment name; use development locally and production in deployed services.
NODE_ENV=development

# Public base URL that browser-side code uses when calling the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Canonical public URL used for metadata, robots, sitemap, and absolute links.
NEXT_PUBLIC_SITE_URL=https://orbit.vorinthex.com

# Publicly exposed backend API key used by browser calls when an endpoint requires the shared API key.
NEXT_PUBLIC_BACKEND_API_KEY=placeholder-backend-api-key

# Server-side backend API base URL used by Next.js route handlers and server components.
API_BASE_URL=http://localhost:3001

# Server-side backend API key used by Next.js route handlers; prefer this over the public key for server-only calls.
BACKEND_API_KEY=placeholder-backend-api-key

# Secret used to sign or encrypt session cookies.
SESSION_COOKIE_SECRET=change-me

# Fallback session secret used by auth/session helpers when SESSION_COOKIE_SECRET is not set.
SESSION_SECRET=change-me
