# Public origin used for canonical URLs, sitemap, robots and Open Graph.
NEXT_PUBLIC_SITE_URL=https://vorinthex.com

# Set to "true" on staging/preview deployments to emit a Disallow-all robots.txt.
NEXT_PUBLIC_BLOCK_INDEXING=false

# Platform backend bridge (server-side only - never exposed to the browser).
# Leave empty for frontend-only development: API routes fall back to local
# stubs so the whole landing experience still works.
BACKEND_API_URL=http://localhost:4000
BACKEND_API_KEY=
