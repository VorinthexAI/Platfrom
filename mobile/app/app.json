{
  "expo": {
    "name": "Vorinthex AI",
    "slug": "vorinthex-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icon.png",
    "scheme": "vorinthexcore",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#030507",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vorinthex.com"
    },
    "android": {
      "package": "app.vorinthex.com",
      "adaptiveIcon": {
        "backgroundColor": "#030507",
        "foregroundImage": "./assets/brand/adaptive-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#030507",
          "image": "./assets/brand/vorinthex-mark.png",
          "imageWidth": 96
        }
      ],
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": false,
          "recordAudioAndroid": false,
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2a9ba74e-cefe-49e6-9fd0-9b38a69c8d18"
      }
    },
    "owner": "vorinthex-ai"
  }
}
