{
  "expo": {
    "name": "Vorinthex AI",
    "slug": "vorinthex-core",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/vorinthex-mark.png",
    "scheme": "vorinthexcore",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#030507",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vorinthex.com"
    },
    "android": {
      "package": "app.vorinthex.com",
      "adaptiveIcon": {
        "backgroundColor": "#030507",
        "foregroundImage": "./assets/brand/vorinthex-mark.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#030507",
          "image": "./assets/brand/vorinthex-mark.png",
          "imageWidth": 96
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
