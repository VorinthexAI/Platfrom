{
  "name": "vorinthex-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "web/landing-pages/*",
    "backend",
    "shared"
  ],
  "scripts": {
    "vorinthex:lint": "bun run --cwd web/landing-pages/vorinthex lint",
    "vorinthex:typecheck": "bun run --cwd web/landing-pages/vorinthex typecheck",
    "cortex-orbit:lint": "bun run --cwd web/landing-pages/cortex-orbit lint",
    "cortex-orbit:typecheck": "bun run --cwd web/landing-pages/cortex-orbit typecheck",
    "backend:check": "bun run --cwd backend check",
    "backend:test": "bun run --cwd backend test"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  }
}
